# Glycemic Ghost Backend Environment Template
# Copy this file to backend/.env and replace placeholder values.
# Never commit backend/.env with real secrets.

# App
PORT=4000
JWT_SECRET=replace-with-a-strong-random-secret

# PostgreSQL
# Local Docker default:
# POSTGRES_URL=postgresql://ghost:ghost@localhost:5432/ghost
# Managed DB example (Neon/Supabase/etc):
# POSTGRES_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
POSTGRES_URL=postgresql://ghost:ghost@localhost:5432/ghost

# Redis
REDIS_URL=redis://localhost:6379

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=replace-with-influx-token
INFLUX_ORG=ghost-org
INFLUX_BUCKET=ghost-cgm

# Dexcom OAuth (Sandbox for development)
DEXCOM_BASE_URL=https://sandbox-api.dexcom.com
DEXCOM_CLIENT_ID=replace-with-dexcom-client-id
DEXCOM_CLIENT_SECRET=replace-with-dexcom-client-secret
DEXCOM_REDIRECT_URI=http://localhost:4000/api/dexcom/callback
DEXCOM_SCOPE=offline_access
